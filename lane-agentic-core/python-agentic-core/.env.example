# Agentic Core environment variables
# Provide a valid GEMINI_API_KEY for Google Generative AI (Gemini) to enable real reasoning.

# Gemini API key (Google Generative AI) — required for real Gemini calls
GEMINI_API_KEY=

# Optional: override storage URL
STORAGE_BASE_URL=http://localhost:8102

# Notes:
# - To obtain a Gemini/Generative AI API key, enable the Generative AI API in your
#   Google Cloud project and create an API key or service account with appropriate access.
# - See Google Cloud documentation for details: https://cloud.google.com/generative-ai
