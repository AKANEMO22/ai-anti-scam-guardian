<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootIncomingCall"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:paddingStart="12dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp">

    <LinearLayout
        android:id="@+id/incomingBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/bg_incoming_banner"
        android:elevation="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="10dp">

            <TextView
                android:id="@+id/tvCaller"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Unknown caller"
                android:textColor="#FFFFFF"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCallState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Viet Nam"
                android:textColor="#A8AFBA"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnDeclineCall"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_call_action_decline"
                android:contentDescription="Decline call"
                android:padding="15dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_call_decline"
                android:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/btnAnswerCall"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_call_action_answer"
                android:contentDescription="Answer call"
                android:padding="15dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_call_answer"
                android:tint="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
