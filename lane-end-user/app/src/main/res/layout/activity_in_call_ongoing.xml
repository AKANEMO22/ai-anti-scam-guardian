<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E1116"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="42dp"
    android:paddingEnd="24dp"
    android:paddingBottom="28dp">

    <TextView
        android:id="@+id/tvOngoingCaller"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Unknown caller"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvOngoingState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Call in progress"
        android:textColor="#A9B0BE"
        android:textSize="16sp" />

    <Chronometer
        android:id="@+id/chronometerCall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#DDE4F1"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnMute"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_soft"
            android:text="Mute"
            android:textAllCaps="false"
            android:textColor="#27374A"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSpeaker"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_soft"
            android:text="Speaker"
            android:textAllCaps="false"
            android:textColor="#27374A"
            android:textStyle="bold" />
    </LinearLayout>

    <Button
        android:id="@+id/btnEndCall"
        android:layout_width="170dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_button_warn"
        android:text="End call"
        android:textAllCaps="false"
        android:textColor="#BE123C"
        android:textStyle="bold" />

</LinearLayout>
