<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_call_screen_gradient">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_call_screen_overlay" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="38dp"
        android:paddingEnd="22dp"
        android:paddingBottom="20dp">

        <ImageView
            android:id="@+id/ivCallerAvatar"
            android:layout_width="108dp"
            android:layout_height="108dp"
            android:background="@drawable/bg_call_avatar_circle"
            android:padding="4dp"
            android:scaleType="centerCrop"
            android:clipToOutline="true"
            android:adjustViewBounds="true"
            android:src="@android:drawable/sym_def_app_icon"
            android:tint="#ffffff"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvCallerLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="Người gọi chưa xác định"
            android:textColor="#ffffff"
            android:textSize="42sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCallMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:text="+84 xxx xxx xxx | Việt Nam HD"
            android:textColor="#d1d5db"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvCallState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Đang đổ chuông..."
            android:textColor="#e5e7eb"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAudioCaptureStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Trạng thái micro: chưa kiểm tra"
            android:textColor="#fbbf24"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvTranscript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:background="@drawable/bg_transcript_box"
            android:text=""
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:maxLines="4"
            android:ellipsize="end" />

        <Chronometer
            android:id="@+id/chronometerCallDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#bbf7d0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvInCallActionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Sẵn sàng"
            android:textColor="#e2e8f0"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvProtectionHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Nhấn Trả lời để bắt đầu theo dõi, hoặc Từ chối để ngắt ngay."
            android:textColor="#cbd5e1"
            android:textSize="12sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/layoutIncomingActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAnswer"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_incoming_btn_answer"
                android:text="Trả lời"
                android:textAllCaps="false"
                android:textColor="#ffffff"
                android:textSize="17sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnDeclineIncoming"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_incoming_btn_decline"
                android:text="Từ chối"
                android:textAllCaps="false"
                android:textColor="#ffffff"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutInCallControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageButton
                        android:id="@+id/btnContact"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_call_action_circle"
                        android:contentDescription="Liên hệ"
                        android:padding="20dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:tint="#ffffff" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Liên hệ"
                        android:textColor="#f8fafc"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageButton
                        android:id="@+id/btnRecord"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_call_action_circle"
                        android:contentDescription="Ghi âm"
                        android:padding="20dp"
                        android:src="@android:drawable/ic_btn_speak_now"
                        android:tint="#ffffff" />

                    <TextView
                        android:id="@+id/tvRecordLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Ghi âm"
                        android:textColor="#f8fafc"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageButton
                        android:id="@+id/btnNote"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_call_action_circle"
                        android:contentDescription="Ghi chú"
                        android:padding="20dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:tint="#ffffff" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Ghi chú"
                        android:textColor="#f8fafc"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageButton
                        android:id="@+id/btnMute"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_call_action_circle"
                        android:contentDescription="Tắt tiếng"
                        android:padding="20dp"
                        android:src="@android:drawable/ic_lock_silent_mode"
                        android:tint="#ffffff" />

                    <TextView
                        android:id="@+id/tvMuteLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tắt tiếng"
                        android:textColor="#f8fafc"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageButton
                        android:id="@+id/btnHold"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_call_action_circle"
                        android:contentDescription="Giữ máy"
                        android:padding="20dp"
                        android:src="@android:drawable/ic_media_pause"
                        android:tint="#ffffff" />

                    <TextView
                        android:id="@+id/tvHoldLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Giữ"
                        android:textColor="#f8fafc"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageButton
                        android:id="@+id/btnSpeaker"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_call_action_circle"
                        android:contentDescription="Loa ngoài"
                        android:padding="20dp"
                        android:src="@android:drawable/ic_lock_silent_mode_off"
                        android:tint="#ffffff" />

                    <TextView
                        android:id="@+id/tvSpeakerLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Loa ngoài"
                        android:textColor="#f8fafc"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutBottomControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/btnDecline"
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:background="@drawable/bg_call_end_circle"
                    android:contentDescription="Kết thúc"
                    android:padding="24dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#ffffff" />

                <TextView
                    android:id="@+id/tvDeclineLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Từ chối"
                    android:textColor="#ffffff"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
