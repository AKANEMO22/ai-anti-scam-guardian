# API Gateway environment variables
# Fill these with real values before running the lane.
# Required (production): set STRICT_AUTH=true and provide a Firebase service account JSON path.

# URL to Agentic Core lane (agentic-core)
AGENTIC_CORE_BASE_URL=http://localhost:8101

# URL to Storage lane
STORAGE_BASE_URL=http://localhost:8102

# Request timeout seconds
REQUEST_TIMEOUT_SECONDS=30

# If you want the gateway to enforce real Firebase ID token verification,
# set STRICT_AUTH=true and provide a valid service account path below.
STRICT_AUTH=false

# Development bearer token (used only when STRICT_AUTH=false)
DEV_BEARER_TOKEN=dev-token

# Path to Firebase service account JSON (download from Firebase Console)
# Example Windows path: C:\Users\you\Downloads\service-account.json
# If set and STRICT_AUTH=true, the API gateway will initialize Firebase Admin SDK
# and call firebase_admin.auth.verify_id_token() to validate incoming ID tokens.
GOOGLE_APPLICATION_CREDENTIALS=

# Notes:
# 1) To create a Firebase service account JSON:
#    - Open Firebase Console -> Project Settings -> Service accounts -> Generate new private key
#    - Save the JSON file and set GOOGLE_APPLICATION_CREDENTIALS to its full path.
# 2) Mobile clients should authenticate with Firebase (Email/Phone/Google/etc.) and send
#    the ID token in the Authorization header: Authorization: Bearer <ID_TOKEN>
